# -----------------------------------------------------------------------------
# Hospital Management System - Production Environment Configurations
# Copy this file to .env or .env.local to load credentials
# -----------------------------------------------------------------------------

# 1. Database Connection (PlanetScale / MySQL)
# Ensure connection pooling holds secure SSL configurations
DATABASE_URL="mysql://user:password@host/dbname?sslaccept=strict"

# 2. JWT Tokens Cryptographics (Should be randomized hashes of min-32 chars)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-long-e-g-abc123xyz"
JWT_REFRESH_SECRET="your-refresh-secret-key-min-32-chars-long-e-g-xyz789abc"

# 3. Twilio WhatsApp Notification APIs
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token_value_here"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# 4. Frontend & Application Descriptors
NEXT_PUBLIC_APP_NAME="Mayo Trust Administrative Hospital Management System"
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# 5. Core Environment Node Target
NODE_ENV="production"
